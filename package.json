{
  "name": "agent-builder-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An engineering-first lab for learning how to build, evaluate, and deploy AI agents.",
  "scripts": {
    "smoke": "tsx src/smoke.ts",
    "agent-builder": "tsx src/runAgentBuilder.ts",
    "eval": "tsx src/evals/runAgentBuilderEvals.ts",
    "api": "tsx src/api/server.ts",
    "web:dev": "nuxt dev web --port 3001",
    "build:web": "nuxt generate web",
    "build": "tsc && npm run build:web",
    "start": "node dist/src/api/server.js"
  },
  "keywords": [
    "agents",
    "ai",
    "typescript",
    "evals"
  ],
  "author": "Ayomide Aremu-Cole",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@lucide/vue": "^1.21.0",
    "@nuxt/ui": "^4.9.0",
    "@openai/agents": "^0.11.5",
    "dotenv": "^17.4.2",
    "hono": "^4.12.26",
    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
